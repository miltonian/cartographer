{
  "name": "cartographer",
  "version": "0.3.5",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/miltonian/cartographer.git"
  },
  "keywords": [
    "code-understanding",
    "codebase-visualization",
    "world-model",
    "claude-code",
    "mcp",
    "semantic-map",
    "developer-tools"
  ],
  "type": "module",
  "scripts": {
    "dev": "concurrently -n svc,ui -c blue,green \"npm run dev:service\" \"npm run dev:ui\"",
    "dev:service": "tsx watch src/index.ts",
    "dev:ui": "vite",
    "build": "npm run build:service && npm run build:ui",
    "build:service": "tsc -p tsconfig.json",
    "build:ui": "vite build",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "cors": "^2.8.5",
    "d3-force": "^3.0.0",
    "express": "^4.21.2",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/d3-force": "^3.0.10",
    "@types/express": "^5.0.1",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.3.4",
    "@xyflow/react": "^12.4.3",
    "concurrently": "^9.1.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.4"
  }
}
